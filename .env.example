# Copy to .env and fill in values for local development.

PORT=8080
LOG_LEVEL=INFO
SERVICE_NAME=n8n-kafka-filter

# ── Auth (Google Sign-In for /ui) ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Leave empty to disable auth (UI is open to anyone)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=dev-secret-change-me-in-production

# Comma-separated emails allowed to access /ui
# Leave empty to allow any authenticated Google user
ALLOWED_EMAILS=

# ── Pipelines ─────────────────────────────────────────────────────────────────
# JSON array — one object per environment.
# In production, store in Secret Manager and reference in service.yaml.
# Filter rules are managed via the /ui — no need to set event_filters here.

# Minimal example (Lambda model — ingest_secret + webhook URL):
PIPELINES_JSON=[{"name":"dev","ingest_secret":"dev-secret-change-me","n8n_webhook_url":"http://localhost:5678/webhook/dev-webhook-id"}]

# Multiple environments:
# PIPELINES_JSON=[
#   {
#     "name": "dev",
#     "ingest_secret": "dev-secret-change-me",
#     "n8n_webhook_url": "https://your-n8n.com/webhook/dev-id"
#   },
#   {
#     "name": "prod",
#     "ingest_secret": "prod-secret-change-me",
#     "n8n_webhook_url": "https://your-n8n.com/webhook/prod-id"
#   }
# ]

# Direct Kafka consumer mode (optional — only if not using Lambda):
# PIPELINES_JSON=[
#   {
#     "name": "dev",
#     "kafka_bootstrap_servers": "b-1.your-cluster.kafka.us-east-1.amazonaws.com:9096",
#     "kafka_topics": ["your-topic"],
#     "kafka_consumer_group_id": "n8n-kafka-filter-dev",
#     "kafka_security_protocol": "SASL_SSL",
#     "kafka_sasl_mechanism": "SCRAM-SHA-512",
#     "kafka_sasl_username": "your-username",
#     "kafka_sasl_password": "your-password",
#     "n8n_webhook_url": "https://your-n8n.com/webhook/abc123"
#   }
# ]
