# Copy to .env and fill in values for local development.
# PIPELINES_JSON is the only required variable — it defines all environments.

PORT=8080
LOG_LEVEL=INFO
SERVICE_NAME=kafka-n8n-forwarder

# PIPELINES_JSON: JSON array of pipeline configs, one per environment.
# In production, store this in Secret Manager and reference it in service.yaml.
#
# Minimal example (no auth, no filtering — forwards everything):
PIPELINES_JSON=[{"name":"dev","kafka_bootstrap_servers":"localhost:9092","kafka_topics":["dev-events"],"kafka_consumer_group_id":"forwarder-dev","n8n_webhook_url":"http://localhost:5678/webhook/dev-webhook-id","filter_mode":"none","filter_rules":[]}]

